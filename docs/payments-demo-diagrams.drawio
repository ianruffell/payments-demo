        <mxCell id="a-e13" value="Live metrics queries" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#0891b2;fontColor=#0e7490;" edge="1" parent="1" source="a-dashboard-services" target="a-gridgain-caches">

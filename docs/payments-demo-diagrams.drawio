  <diagram id="cdc-archive-flow" name="CDC and Archive Data Flow">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="d-title" value="Reference Data CDC, Active Cache State, and Archive Flow" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1660" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="d-note" value="This page separates durable system-of-record data from hot GridGain state and shows how CDC keeps reference caches current while terminal payments are archived out of GridGain." style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#4b5563;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="72" width="1660" height="34" as="geometry"/>
        </mxCell>

        <mxCell id="d-env" value="Runtime selection&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;.env.mariadb or .env.oracle chooses JDBC URL, schema, connector name, and CDC topics&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="130" width="330" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="d-seed" value="SeedDataLoader&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Initialize schema, seed accounts and merchants when empty, enable reference-table CDC, refresh caches&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="310" width="330" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="d-admin" value="Merchant Admin UI&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Toggle merchant active flag and update GridGain immediately&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;" vertex="1" parent="1">
          <mxGeometry x="60" y="500" width="330" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="d-sor" value="System of Record Database&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Oracle or MariaDB&lt;br&gt;accounts, merchants, payments, merchant attempts, ledger entries&lt;/font&gt;" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fef3c7;strokeColor=#d97706;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="300" width="300" height="155" as="geometry"/>
        </mxCell>
        <mxCell id="d-debezium" value="Debezium Connector&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;MariaDB binlog or Oracle LogMiner&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="180" width="260" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="d-kafka" value="Kafka&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Reference topics:&lt;br&gt;ACCOUNTS and MERCHANTS&lt;/font&gt;" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ffedd5;strokeColor=#ea580c;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="345" width="260" height="104" as="geometry"/>
        </mxCell>
        <mxCell id="d-sink" value="ReferenceCacheSinkService&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Kafka consumer group payments-reference-cache-sink&lt;br&gt;Applies c/u/d events to GridGain&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="540" width="260" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="d-gridgain" value="GridGain Hot State&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Reference caches: accounts, merchants&lt;br&gt;Active transaction caches: payments, ledger_entries, merchant_payment_attempts&lt;/font&gt;" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#cffafe;strokeColor=#0891b2;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1290" y="300" width="350" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="d-app" value="payments-demo-app&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;PaymentService, DashboardService, TransactionFlowService, ArchiveService&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1290" y="570" width="350" height="104" as="geometry"/>
        </mxCell>
        <mxCell id="d-terminal" value="Terminal payments&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;DECLINED, TIMED_OUT, REFUNDED, CAPTURED after retention&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1290" y="770" width="350" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="d-dashboard" value="Dashboard and flow views&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Active rows from GridGain plus recent archived rows from DB&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;" vertex="1" parent="1">
          <mxGeometry x="900" y="790" width="300" height="86" as="geometry"/>
        </mxCell>

        <mxCell id="d-e1" value="configuration" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#64748b;" edge="1" parent="1" source="d-env" target="d-sor"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e2" value="seed durable reference data" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;" edge="1" parent="1" source="d-seed" target="d-sor"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e3" value="initial cache refresh" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#0891b2;" edge="1" parent="1" source="d-seed" target="d-gridgain"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e4" value="merchant status write" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#2563eb;" edge="1" parent="1" source="d-admin" target="d-sor"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e5" value="immediate cache update" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#2563eb;" edge="1" parent="1" source="d-admin" target="d-gridgain"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e6" value="change log" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;" edge="1" parent="1" source="d-sor" target="d-debezium"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e7" value="publish reference events" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;" edge="1" parent="1" source="d-debezium" target="d-kafka"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e8" value="consume topics" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;" edge="1" parent="1" source="d-kafka" target="d-sink"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e9" value="upsert / delete accounts and merchants" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#0891b2;" edge="1" parent="1" source="d-sink" target="d-gridgain"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e10" value="authorizations mutate active cache state" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;" edge="1" parent="1" source="d-app" target="d-gridgain"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e11" value="eligible terminal states" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#dc2626;" edge="1" parent="1" source="d-gridgain" target="d-terminal"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e12" value="archive write" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#d97706;" edge="1" parent="1" source="d-terminal" target="d-sor"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e13" value="remove archived active rows" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#0891b2;dashed=1;" edge="1" parent="1" source="d-terminal" target="d-gridgain"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e14" value="active metrics" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#2563eb;" edge="1" parent="1" source="d-gridgain" target="d-dashboard"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d-e15" value="recent archived metrics" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#2563eb;" edge="1" parent="1" source="d-sor" target="d-dashboard"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  </diagram>

  <diagram id="payment-lifecycle" name="Payment Lifecycle Flow">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p-title" value="Payment Authorization, Settlement, Timeout, and Archive Flow" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1660" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p-note" value="This page follows one payment from API request through GridGain transactional state, merchant callback, capture/refund, timeout handling, and eventual archive to the system of record." style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#4b5563;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="72" width="1660" height="34" as="geometry"/>
        </mxCell>

        <mxCell id="p-start" value="1. Payment request&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;UI or initiator posts /api/payments/authorize&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="170" width="230" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="p-controller" value="PaymentController&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Validates request envelope and calls PaymentService&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;" vertex="1" parent="1">
          <mxGeometry x="360" y="170" width="240" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="p-duplicate" value="2. Duplicate checks&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Look in archived payments, then active payments cache&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;" vertex="1" parent="1">
          <mxGeometry x="670" y="170" width="250" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="p-load-ref" value="3. Load reference data&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;accounts + merchants from GridGain; fallback to system of record on miss&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cffafe;strokeColor=#0891b2;" vertex="1" parent="1">
          <mxGeometry x="990" y="170" width="280" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="p-validate" value="4. Score and validate&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Fraud score, account status, currency, merchant active, limits, funds&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbf7d0;strokeColor=#15803d;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1340" y="170" width="300" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="p-decision" value="Valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1425" y="330" width="130" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="p-declined" value="DECLINED&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Write Payment with decline reason&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1190" y="505" width="250" height="84" as="geometry"/>
        </mxCell>
        <mxCell id="p-pending" value="PENDING_MERCHANT&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Transactional write: Payment + MerchantPaymentAttempt=PENDING&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1520" y="505" width="250" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="p-dispatch" value="5. Async merchant dispatch&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;POST to merchant service URL with callback and deadline&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;" vertex="1" parent="1">
          <mxGeometry x="1320" y="675" width="300" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="p-merchant" value="Merchant simulator&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Approve, decline, delay, or fail to respond&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="675" width="260" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="p-callback" value="6. Merchant callback&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;POST /api/merchant-results&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;" vertex="1" parent="1">
          <mxGeometry x="670" y="675" width="240" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="p-result-decision" value="Approved before deadline?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="385" y="660" width="170" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="p-authorized" value="AUTHORIZED&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Debit account available balance and write ledger AUTH_HOLD&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="260" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="p-merchant-decline" value="DECLINED or TIMED_OUT&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Merchant declined, late response, or timeout monitor expired attempt&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="785" width="260" height="96" as="geometry"/>
        </mxCell>

        <mxCell id="p-capture" value="7. Capture endpoint&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;AUTHORIZED to CAPTURED; write ledger CAPTURE&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;" vertex="1" parent="1">
          <mxGeometry x="390" y="920" width="260" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="p-refund" value="8. Refund endpoint&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;CAPTURED to REFUNDED; credit account and write ledger REFUND&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;" vertex="1" parent="1">
          <mxGeometry x="730" y="920" width="280" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="p-archive" value="9. Archive completed payment&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Persist terminal payment, attempt, and ledger entries to system of record; remove from GridGain&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1130" y="910" width="330" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="p-dashboard" value="Dashboard and flow UI&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Query active GridGain rows plus recent archived rows for charts&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;" vertex="1" parent="1">
          <mxGeometry x="1510" y="910" width="250" height="98" as="geometry"/>
        </mxCell>


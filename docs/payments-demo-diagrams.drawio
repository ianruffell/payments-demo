<mxfile host="app.diagrams.net" modified="2026-05-22T10:45:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="system-architecture" name="System Architecture">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="a-title" value="GridGain Payments Demo - System Architecture" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1660" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a-note" value="Docker Compose project with MariaDB or Oracle system of record, Debezium CDC, Kafka, GridGain 8, Spring Boot services, merchant simulators, and optional Control Center." style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#4b5563;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="72" width="1660" height="34" as="geometry"/>
        </mxCell>

        <mxCell id="a-client-lane" value="Users and Traffic Sources" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#94a3b8;fontStyle=1;fontSize=16;verticalAlign=top;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="270" height="660" as="geometry"/>
        </mxCell>
        <mxCell id="a-browser" value="Browser UI&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Dashboard, controls, flow view&lt;br&gt;localhost:8080&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="180" width="210" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="a-initiator" value="Payment Initiator&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Generates authorize, capture, refund traffic&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="330" width="210" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="a-merchants" value="Merchant Simulators&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;merchant-00001 ... merchant-00005&lt;br&gt;Approve, decline, or timeout&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="500" width="210" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="a-app-lane" value="payments-demo-app - Spring Boot Processor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontStyle=1;fontSize=16;verticalAlign=top;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="120" width="430" height="660" as="geometry"/>
        </mxCell>
        <mxCell id="a-controllers" value="REST Controllers and Static UI&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;/api/payments, /api/dashboard, /api/flow, /api/admin&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;" vertex="1" parent="1">
          <mxGeometry x="405" y="180" width="360" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="a-payment-service" value="PaymentService&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Duplicate checks, validation, fraud scoring, transactional cache updates&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbf7d0;strokeColor=#15803d;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="405" y="300" width="360" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="a-workers" value="Background and Integration Services&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;MerchantDispatchService, MerchantTimeoutMonitor, CompletedPaymentArchiveService&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;" vertex="1" parent="1">
          <mxGeometry x="405" y="435" width="360" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="a-dashboard-services" value="DashboardService and TransactionFlowService&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Read GridGain active state plus recently archived rows&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;" vertex="1" parent="1">
          <mxGeometry x="405" y="575" width="360" height="82" as="geometry"/>
        </mxCell>
        <mxCell id="a-seed-admin" value="SeedDataLoader and MerchantAdminService&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Initialize schema, seed reference data, update merchant status&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;" vertex="1" parent="1">
          <mxGeometry x="405" y="690" width="360" height="68" as="geometry"/>
        </mxCell>

        <mxCell id="a-gridgain-lane" value="GridGain 8 Cluster - 3 Nodes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfeff;strokeColor=#0891b2;fontStyle=1;fontSize=16;verticalAlign=top;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="870" y="120" width="420" height="430" as="geometry"/>
        </mxCell>
        <mxCell id="a-gridgain-caches" value="Transactional Partitioned Caches&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;backups=1, SQL indexed, PUBLIC schema&lt;/font&gt;" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#cffafe;strokeColor=#0891b2;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="920" y="190" width="320" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="a-cache-list" value="accounts&lt;br&gt;merchants&lt;br&gt;payments&lt;br&gt;ledger_entries&lt;br&gt;merchant_payment_attempts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdfa;strokeColor=#0e7490;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="920" y="335" width="320" height="145" as="geometry"/>
        </mxCell>

        <mxCell id="a-db" value="System of Record&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;MariaDB or Oracle&lt;br&gt;accounts, merchants, archived payments, ledger rows&lt;/font&gt;" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fef3c7;strokeColor=#d97706;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="930" y="640" width="300" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="a-cdc-lane" value="CDC and Messaging" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontStyle=1;fontSize=16;verticalAlign=top;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="1360" y="420" width="330" height="360" as="geometry"/>
        </mxCell>
        <mxCell id="a-debezium" value="Kafka Connect + Debezium&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Reads binlog / LogMiner changes&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1400" y="500" width="250" height="78" as="geometry"/>
        </mxCell>
        <mxCell id="a-kafka" value="Kafka Topics&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;paymentsdemo.&amp;lt;schema&amp;gt;.ACCOUNTS&lt;br&gt;paymentsdemo.&amp;lt;schema&amp;gt;.MERCHANTS&lt;/font&gt;" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ffedd5;strokeColor=#ea580c;" vertex="1" parent="1">
          <mxGeometry x="1400" y="615" width="250" height="88" as="geometry"/>
        </mxCell>
        <mxCell id="a-reference-sink" value="Reference Cache Sink&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Consumes CDC and updates accounts / merchants caches&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1400" y="725" width="250" height="78" as="geometry"/>
        </mxCell>

        <mxCell id="a-cc-lane" value="Optional Control Center Add-on" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#8b5cf6;fontStyle=1;fontSize=16;verticalAlign=top;spacingTop=12;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1360" y="120" width="330" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="a-cc-ui" value="Control Center Frontend&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;localhost:8008&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;" vertex="1" parent="1">
          <mxGeometry x="1400" y="180" width="250" height="62" as="geometry"/>
        </mxCell>
        <mxCell id="a-cc-backend" value="Control Center Backend&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;localhost:3000&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;" vertex="1" parent="1">
          <mxGeometry x="1400" y="265" width="250" height="62" as="geometry"/>
        </mxCell>
        <mxCell id="a-network-note" value="Networks&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;Base demo: gridgain_default&lt;br&gt;Control Center add-on: gridgain_control-center&lt;br&gt;GridGain nodes join both when add-on is used&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="820" width="820" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="a-e1" value="HTTP UI and control API" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#2563eb;fontColor=#1d4ed8;" edge="1" parent="1" source="a-browser" target="a-controllers">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-e2" value="Generated REST traffic" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#7c3aed;fontColor=#6d28d9;" edge="1" parent="1" source="a-initiator" target="a-controllers">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-e3" value="Authorize / capture / refund" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;" edge="1" parent="1" source="a-controllers" target="a-payment-service">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-e4" value="Transactional cache reads and writes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#0891b2;fontColor=#0e7490;" edge="1" parent="1" source="a-payment-service" target="a-gridgain-caches">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-e5" value="Dispatch merchant request" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;fontColor=#c2410c;" edge="1" parent="1" source="a-workers" target="a-merchants">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="250" y="555" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="a-e6" value="Merchant result callback" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;fontColor=#c2410c;" edge="1" parent="1" source="a-merchants" target="a-controllers">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-e7" value="Seed, fallback reads, archive terminal payments" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#d97706;fontColor=#b45309;" edge="1" parent="1" source="a-seed-admin" target="a-db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-e8" value="Archive service writes completed payments" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#d97706;fontColor=#b45309;" edge="1" parent="1" source="a-workers" target="a-db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-e9" value="DB change log" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;" edge="1" parent="1" source="a-db" target="a-debezium">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-e10" value="Reference data events" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;" edge="1" parent="1" source="a-debezium" target="a-kafka">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-e11" value="Consume" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;" edge="1" parent="1" source="a-kafka" target="a-reference-sink">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-e12" value="Upsert / remove reference caches" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#0891b2;fontColor=#0e7490;" edge="1" parent="1" source="a-reference-sink" target="a-gridgain-caches">
          <mxGeometry relative="1" as="geometry"/>
